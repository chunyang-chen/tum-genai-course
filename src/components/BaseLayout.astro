---
import "../styles/global.css";
import { navigation, siteMeta } from "../content/site";
import { isExternalUrl } from "../utils/links";
import Footer from "./Footer.astro";

type Crumb = {
  name: string;
  href: string;
};

interface Props {
  title?: string;
  description?: string;
  path?: string;
  breadcrumbs?: Crumb[];
  schema?: Record<string, unknown> | Array<Record<string, unknown>>;
  showSearch?: boolean;
}

const { title, description = siteMeta.description, path = "/", breadcrumbs = [], schema, showSearch = false } = Astro.props;

const pageTitleText = title ? `${title} | ${siteMeta.siteName}` : `${siteMeta.title} | ${siteMeta.siteName}`;
const siteBase = new URL(import.meta.env.BASE_URL, Astro.site);
const canonicalPath = path === "/" ? "" : path.replace(/^\//, "");
const canonical = new URL(canonicalPath, siteBase).toString();
const ogImage = new URL("og-default.svg", siteBase).toString();
const extraSchema = schema ? (Array.isArray(schema) ? schema : [schema]) : [];
const breadcrumbItems = breadcrumbs.map((crumb, index) => ({
  "@type": "ListItem",
  position: index + 1,
  name: crumb.name,
  item: new URL(crumb.href.replace(/^\//, ""), siteBase).toString()
}));

const baseSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "CollegeOrUniversity",
      name: siteMeta.institution,
      url: siteMeta.organizationUrl
    },
    {
      "@type": "Course",
      name: siteMeta.title,
      description: siteMeta.description,
      educationalCredentialAwarded: siteMeta.code,
      inLanguage: siteMeta.language,
      url: new URL("", siteBase).toString(),
      provider: {
        "@type": "CollegeOrUniversity",
        name: siteMeta.institution,
        url: siteMeta.organizationUrl
      },
      instructor: {
        "@type": "Person",
        name: siteMeta.lecturer
      }
    },
    ...(breadcrumbItems.length
      ? [
          {
            "@type": "BreadcrumbList",
            itemListElement: breadcrumbItems
          }
        ]
      : [])
  ]
};

const basePrefix = import.meta.env.BASE_URL === "/" ? "" : import.meta.env.BASE_URL.replace(/\/$/, "");
const withBase = (href: string) => {
  if (/^(https?:)?\/\//.test(href) || href.startsWith("#")) {
    return href;
  }

  if (href === "/") {
    return basePrefix || "/";
  }

  return `${basePrefix}${href}`;
};
---

<!DOCTYPE html>
<html lang="en" class="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitleText}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1" />
    <meta name="theme-color" content="#004d93" />
    <meta name="format-detection" content="telephone=no" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteMeta.siteName} />
    <meta property="og:title" content={pageTitleText} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitleText} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700;800&family=Inter:wght@300;400;500;600;700&family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
      rel="stylesheet"
    />

    <script is:inline type="application/ld+json" set:html={JSON.stringify(baseSchema)} />
    {extraSchema.map((entry) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(entry)} />
    ))}
  </head>

  <body class="bg-background text-on-surface font-body selection:bg-primary-fixed selection:text-on-primary-fixed">
    <a class="skip-link" href="#content">Skip to content</a>

    <nav class="glass-nav fixed top-0 z-50 w-full border-b border-outline-variant/30 bg-white/80 backdrop-blur-xl">
      <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-6 md:h-20">
        <div class="flex items-center gap-8">
          <a href={withBase("/")} class="text-xl font-bold tracking-tight text-blue-900 font-headline">
            {siteMeta.shortTitle}
          </a>

          <div class="hidden items-center space-x-8 md:flex">
            {navigation.map((item) => (
              <a
                href={withBase(item.href)}
                class:list={[
                  "font-headline tracking-tight transition-colors",
                  path === item.href
                    ? "border-b-2 border-blue-700 pb-1 font-bold text-blue-700"
                    : "text-slate-600 hover:text-blue-600"
                ]}
              >
                {item.label}
              </a>
            ))}
          </div>
        </div>

        <div class="flex items-center gap-4">
          {showSearch && (
            <button
              type="button"
              class="material-symbols-outlined rounded-full p-2 text-on-surface-variant transition-colors hover:bg-slate-50/50"
              aria-label="Search"
            >
              search
            </button>
          )}
          <a
            href={siteMeta.officialUrl}
            target={isExternalUrl(siteMeta.officialUrl) ? "_blank" : undefined}
            rel={isExternalUrl(siteMeta.officialUrl) ? "noopener noreferrer" : undefined}
            class="rounded-md bg-gradient-to-br from-primary to-primary-container px-5 py-2 text-sm font-semibold text-on-primary shadow-md transition-all hover:opacity-90 md:px-6 md:py-2.5 font-headline"
          >
            Enroll Now
          </a>
        </div>
      </div>
    </nav>

    <div id="content">
      <slot />
    </div>

    <Footer />

    <script is:inline>
      document.querySelectorAll("[data-tab-group]").forEach((group) => {
        const triggers = Array.from(group.querySelectorAll("[data-tab-trigger]"));
        const panels = Array.from(group.querySelectorAll("[data-tab-panel]"));
        const defaultTab = group.getAttribute("data-default-tab");

        const activate = (tabId) => {
          triggers.forEach((trigger) => {
            const active = trigger.getAttribute("data-tab-trigger") === tabId;
            trigger.setAttribute("aria-selected", String(active));
            trigger.classList.toggle("bg-primary", active);
            trigger.classList.toggle("text-on-primary", active);
            trigger.classList.toggle("shadow-sm", active);
            trigger.classList.toggle("font-semibold", active);
            trigger.classList.toggle("text-on-surface-variant", !active);
            trigger.classList.toggle("hover:bg-surface-container-highest", !active);
          });

          panels.forEach((panel) => {
            const active = panel.getAttribute("data-tab-panel") === tabId;
            panel.toggleAttribute("hidden", !active);
          });
        };

        if (defaultTab) {
          activate(defaultTab);
        }

        triggers.forEach((trigger) => {
          trigger.addEventListener("click", () => {
            const tabId = trigger.getAttribute("data-tab-trigger");
            if (tabId) {
              activate(tabId);
            }
          });
        });
      });
    </script>
  </body>
</html>

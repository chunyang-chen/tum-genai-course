---
import { withBasePath } from "../utils/links";

interface Props {
  eyebrow: string;
  title: string;
  body: string;
  tags: string[];
  initials: string;
  imageSrc?: string;
  videoSrc?: string;
  placeholder?: boolean;
}

const { eyebrow, title, body, tags, initials, imageSrc, videoSrc, placeholder = false } = Astro.props;
const resolvedImageSrc = imageSrc ? withBasePath(imageSrc, import.meta.env.BASE_URL) : undefined;
const resolvedVideoSrc = videoSrc ? withBasePath(videoSrc, import.meta.env.BASE_URL) : undefined;
---

<article
  class:list={[
    placeholder
      ? "flex flex-col items-center justify-center rounded-xl border-2 border-dashed border-outline-variant/30 bg-surface-container p-8 text-center"
      : "ambient-card-hover rounded-xl border border-transparent bg-surface-container-lowest p-4"
  ]}
>
  {placeholder ? (
    <>
      <span class="material-symbols-outlined mb-4 text-5xl text-outline">add_circle</span>
      <h3 class="mb-2 font-headline text-lg font-bold text-secondary">{title}</h3>
      <p class="max-w-[220px] text-sm text-on-surface-variant">{body}</p>
    </>
  ) : (
    <>
      <div class="group relative mb-6 aspect-video cursor-pointer overflow-hidden rounded-lg bg-surface-container-low">
        {resolvedVideoSrc ? (
          <video
            src={resolvedVideoSrc}
            controls
            playsinline
            preload="metadata"
            class="h-full w-full object-cover"
          />
        ) : resolvedImageSrc ? (
          <img src={resolvedImageSrc} alt={`${title} project placeholder visual`} class="h-full w-full object-cover" />
        ) : (
          <div class="placeholder-image relative flex h-full w-full items-center justify-center">
            <span class="font-headline text-5xl font-extrabold tracking-[0.2em] text-white/80">{initials}</span>
          </div>
        )}
      </div>

      <div class="px-2">
        <span class="mb-1 block text-[10px] font-bold uppercase tracking-widest text-primary">{eyebrow}</span>
        <h3 class="font-headline text-xl font-bold">{title}</h3>
        <p class="mb-6 mt-4 text-sm leading-relaxed text-on-surface-variant">{body}</p>
        <div class="flex flex-wrap gap-2 border-t border-surface-container pt-4">
          {tags.map((tag, index) => (
            <>
              <span class="text-[11px] font-medium text-secondary">{tag}</span>
              {index < tags.length - 1 && <span class="text-[9px] font-bold text-outline-variant/60 select-none">·</span>}
            </>
          ))}
        </div>
      </div>
    </>
  )}
</article>

---
import { siteMeta } from "../content/site";

const basePrefix = import.meta.env.BASE_URL === "/" ? "" : import.meta.env.BASE_URL.replace(/\/$/, "");
const withBase = (href: string) => {
  if (/^(https?:)?\/\//.test(href) || href.startsWith("#")) {
    return href;
  }
  if (href === "/") {
    return basePrefix || "/";
  }
  return `${basePrefix}${href}`;
};

const year = new Date().getFullYear();
---

<footer class="mt-24 border-t border-outline-variant/40 bg-surface-container-lowest">
  <div class="mx-auto flex max-w-7xl flex-col items-start justify-between gap-4 px-6 py-8 text-sm text-on-surface-variant md:flex-row md:items-center">
    <p>
      &copy; {year} Chair of Software Engineering &amp; AI &middot; {siteMeta.institution}
    </p>
    <nav aria-label="Legal" class="flex flex-wrap gap-x-6 gap-y-2">
      <a href={withBase("/impressum")} class="hover:text-primary transition-colors">Impressum</a>
      <a href={withBase("/datenschutz")} class="hover:text-primary transition-colors">Datenschutzerkl&auml;rung</a>
      <a
        href="https://www.tum.de/en/accessibility"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-primary transition-colors"
      >Accessibility</a>
    </nav>
  </div>
</footer>

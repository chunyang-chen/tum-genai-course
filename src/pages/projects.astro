---
import BaseLayout from "../components/BaseLayout.astro";
import ProjectTile from "../components/ProjectTile.astro";
import { getAllProjectsForGallery, projectLifecycle, showcaseMedia, siteMeta } from "../content/site";

const projectGallery = getAllProjectsForGallery();

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: `${siteMeta.title} projects`,
  description: "Student project gallery for the TUM generative AI course.",
  url: new URL("/projects", Astro.site).toString()
};

const basePrefix = import.meta.env.BASE_URL === "/" ? "" : import.meta.env.BASE_URL.replace(/\/$/, "");
const videoSrc = `${basePrefix}/GenAI_project_demo.mp4`;
---

<BaseLayout
  title="Projects"
  description="Student project gallery for Foundations and Application of Generative AI."
  path="/projects"
  breadcrumbs={[{ name: "Projects", href: "/projects" }]}
  schema={schema}
>
  <main class="pb-24 pt-32">
    <section class="mx-auto mb-20 max-w-7xl px-6">
      <div class="grid grid-cols-1 items-start gap-12 min-[900px]:grid-cols-12">
        <div class="min-[900px]:col-span-7">
          <span class="mb-4 block text-xs font-bold uppercase tracking-widest text-primary font-headline">
            Experimental Excellence
          </span>
          <h1 class="mb-8 font-headline text-6xl font-extrabold tracking-tight text-on-surface">
            Student Innovation <span class="text-primary">Gallery</span>
          </h1>
          <p class="mb-12 max-w-2xl text-lg leading-relaxed text-on-surface-variant">
            Witness the convergence of academic rigor and generative intelligence. Students move from
            proposal to implementation and presentation while building tangible AI systems.
          </p>

          <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
            {projectLifecycle.map((step, index) => (
              <div class="rounded-xl bg-surface-container-low p-6">
                <span class="material-symbols-outlined mb-4 text-primary">
                  {["lightbulb", "terminal", "present_to_all"][index]}
                </span>
                <h3 class="mb-2 font-headline text-lg font-bold">{step.title}</h3>
                <p class="text-sm text-on-surface-variant">{step.body}</p>
              </div>
            ))}
          </div>
        </div>

        <div class="relative min-[900px]:col-span-5">
          <div class="relative aspect-square overflow-hidden rounded-[2rem] bg-surface-container-highest">
            <img src={showcaseMedia.projectHero} alt="Project showcase visual" class="h-full w-full object-cover" />
            <div class="absolute inset-0 bg-primary/10 mix-blend-multiply"></div>
          </div>

          <div class="absolute -bottom-6 left-4 max-w-xs rounded-xl border border-white/20 bg-surface/60 p-6 shadow-xl backdrop-blur-xl min-[900px]:-left-6">
            <div class="mb-2 flex items-center gap-3">
              <span
                class="material-symbols-outlined text-primary"
                style="font-variation-settings: 'FILL' 1;"
              >
                auto_awesome
              </span>
              <span class="text-xs font-bold uppercase tracking-widest text-primary">AI Insight</span>
            </div>
            <p class="text-xs italic leading-relaxed text-on-surface-variant">
              "Projects are framed to connect prompting, orchestration, evaluation, and domain-specific
              implementation choices."
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="mx-auto mb-20 max-w-7xl px-6">
      <div class="overflow-hidden rounded-2xl bg-surface-container-low shadow-lg">
        <div class="p-8">
          <div class="mb-6 text-center">
            <span class="mb-3 inline-block text-xs font-bold uppercase tracking-widest text-primary">
              Project Showcase
            </span>
            <h2 class="mb-3 text-3xl font-bold text-on-surface">
              Demo Video
            </h2>
            <p class="text-sm text-on-surface-variant">
              Watch student projects through practical demonstrations
            </p>
          </div>
          <div class="relative aspect-video w-full overflow-hidden rounded-xl bg-surface-container-highest">
            <video
              controls
              class="h-full w-full object-contain"
              preload="metadata"
            >
              <source src={videoSrc} type="video/mp4" />
              Your browser does not support the video tag.
            </video>
          </div>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-7xl px-6">
      <section class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
        {projectGallery.map((project) => (
          <ProjectTile
            initials={project.initials}
            eyebrow={project.domain}
            title={project.title}
            body={project.summary}
            tags={project.themes}
            imageSrc={project.imageSrc}
            placeholder={project.isPlaceholder}
          />
        ))}
      </section>
    </section>
  </main>
</BaseLayout>

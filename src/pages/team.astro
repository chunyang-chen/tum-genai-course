---
import BaseLayout from "../components/BaseLayout.astro";
import SemesterTabs from "../components/SemesterTabs.astro";
import { getSemesterTutorSlots, getTeamSemesters, lecturerProfile, siteMeta } from "../content/site";
import { withBasePath } from "../utils/links";

const visibleSemesters = getTeamSemesters();
const defaultTutorSemester = visibleSemesters[0]?.id ?? "ss-2026";

const schema = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  name: `${siteMeta.title} team`,
  description: "Lead instructor and semester-based teaching support archive for the TUM generative AI course.",
  url: new URL("/team", Astro.site).toString()
};
---

<BaseLayout
  title="Team"
  description="Lead instructor and semester-based teaching support archive."
  path="/team"
  breadcrumbs={[{ name: "Team", href: "/team" }]}
  schema={schema}
>
  <main class="mx-auto max-w-7xl px-6 pb-24 pt-32">
    <header class="mb-20">
      <h1 class="mb-6 bg-gradient-to-r from-primary to-tertiary bg-clip-text font-headline text-5xl font-extrabold tracking-tight text-transparent lg:text-6xl">
        The Team
      </h1>
      <p class="max-w-2xl text-lg font-light leading-relaxed text-on-surface-variant">
        Meet the faculty, researchers, and mentors dedicated to exploring the boundaries of generative AI.
      </p>
    </header>

    <section class="mb-32">
      <div class="grid grid-cols-1 items-stretch gap-8 lg:grid-cols-12">
        <div class="group relative lg:col-span-5">
          <div class="absolute -inset-4 rounded-full bg-primary-fixed opacity-10 blur-3xl"></div>
          <img
            class="relative z-10 h-[500px] w-full rounded-xl object-cover shadow-sm"
            src={withBasePath(lecturerProfile.imageSrc, import.meta.env.BASE_URL)}
            alt={`Portrait of ${lecturerProfile.name}`}
          />
        </div>

        <div class="relative flex flex-col justify-center rounded-xl bg-surface-container-lowest p-10 lg:col-span-7 lg:p-16">
          <span class="mb-4 block text-xs font-bold uppercase tracking-widest text-primary">
            {lecturerProfile.title}
          </span>
          <h2 class="mb-4 text-4xl font-bold">{lecturerProfile.name}</h2>
          <h3 class="mb-8 text-xl font-medium text-on-surface-variant">{lecturerProfile.role}</h3>
          <div class="space-y-6 text-lg leading-relaxed text-on-surface">
            <p>{lecturerProfile.quote}</p>
          </div>
          <div class="mt-10 flex flex-wrap gap-4">
            <div class="rounded-xl border-l-4 border-primary bg-surface-container-low px-6 py-4">
              <span class="mb-1 block text-xs font-bold uppercase text-outline">Focus Area</span>
              <span class="font-bold">{lecturerProfile.focusArea}</span>
            </div>
            <div class="rounded-xl border-l-4 border-tertiary bg-surface-container-low px-6 py-4">
              <span class="mb-1 block text-xs font-bold uppercase text-outline">Affiliation</span>
              <span class="font-bold">{lecturerProfile.affiliation}</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="mb-32">
      <div class="mb-12 flex items-end justify-between">
        <div>
          <h2 class="mb-2 text-3xl font-bold tracking-tight">Tutors</h2>
          <p class="text-on-surface-variant">
            Semester-based public teaching support is shown across the course timeline, with placeholders where public tutor data is still unavailable.
          </p>
        </div>
      </div>

      <SemesterTabs tabs={visibleSemesters} defaultTab={defaultTutorSemester} compact={true}>
        {visibleSemesters.map((semester) => (
          <section data-tab-panel={semester.id} class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
            {getSemesterTutorSlots(semester.id).map((person) => (
              <article class="group rounded-xl bg-surface-container-low p-1 transition-all duration-300 hover:bg-surface-bright">
                <div class="h-full rounded-lg bg-surface-container-lowest p-6">
                  <div class="mb-6 flex items-center gap-4">
                    {person.imageSrc ? (
                      <img class="h-16 w-16 rounded-full object-cover" src={withBasePath(person.imageSrc, import.meta.env.BASE_URL)} alt={`Portrait of ${person.name}`} />
                    ) : (
                      <div class="placeholder-portrait relative h-16 w-16 rounded-full" data-initials={person.initials}></div>
                    )}
                    <div>
                      <h4 class="text-lg font-bold">{person.name}</h4>
                      <span class="text-xs font-semibold text-primary">{person.role}</span>
                    </div>
                  </div>
                  <p class="text-sm text-on-surface-variant">{person.bio}</p>
                </div>
              </article>
            ))}
          </section>
        ))}
      </SemesterTabs>
    </section>
  </main>
</BaseLayout>

---
import BaseLayout from "../components/BaseLayout.astro";
import PortraitCard from "../components/PortraitCard.astro";
import SemesterTabs from "../components/SemesterTabs.astro";
import { getInsightsSemesters, getSemesterLectureSlots, latestInsightsSemesterId, siteMeta } from "../content/site";

const visibleSemesters = getInsightsSemesters();

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: `${siteMeta.title} insights`,
  description: "Semester-based guest insights archive for the TUM generative AI course.",
  url: new URL("/insights", Astro.site).toString()
};
---

<BaseLayout
  title="Insights"
  description="Semester-based guest insights archive for Foundations and Application of Generative AI."
  path="/insights"
  breadcrumbs={[{ name: "Insights", href: "/insights" }]}
  schema={schema}
  showSearch={true}
>
  <main class="mx-auto max-w-7xl px-6 pb-24 pt-32">
    <section class="mb-20">
      <h1 class="mb-6 font-headline text-5xl font-extrabold leading-[1.1] tracking-tight text-on-surface lg:text-6xl">
        Expert Perspectives
      </h1>
      <p class="max-w-2xl text-lg font-light leading-relaxed text-on-surface-variant">
        Bringing the frontier of large language models and generative systems from industrial
        research labs to the lecture hall.
      </p>
    </section>

    <SemesterTabs tabs={visibleSemesters} defaultTab={latestInsightsSemesterId}>
      {visibleSemesters.map((semester) => {
        const lectures = getSemesterLectureSlots(semester.id);
        const twoUp = lectures.length === 2;

        return (
          <section
            data-tab-panel={semester.id}
            class:list={[
              "grid grid-cols-1 gap-8",
              twoUp ? "mx-auto md:max-w-5xl md:grid-cols-2 lg:grid-cols-2" : "md:grid-cols-2 lg:grid-cols-3"
            ]}
          >
            {lectures.map((lecture, index) => (
              <PortraitCard
                initials={lecture.initials}
                eyebrow={lecture.affiliation}
                title={lecture.speaker}
                subtitle={lecture.topic}
                body={lecture.summary}
                note="Speaker profile"
                imageSrc={lecture.imageSrc}
                placeholder={false}
                offset={!twoUp && index === 1}
              />
            ))}
          </section>
        );
      })}
    </SemesterTabs>
  </main>
</BaseLayout>
